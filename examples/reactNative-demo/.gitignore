# iOS Generated/Build files
ios/Frameworks/
*.xcworkspace/xcuserdata/
*.xcworkspace/contents.xcworkspacedata.bak

# iOS SDK Frameworks (these are large binary files that should not be in Git)
ios/Frameworks/*.framework/
ios/Frameworks/*.xcframework/
ios/**/*.framework
ios/**/*.xcframework

# Xcode project files that get regenerated or are duplicates
*.xcodeproj/project.pbxproj.bak
*-Bridging-Header*.h
*Bridging-Header*.h

# Duplicate/backup directories created by Xcode
**/PlaudSDK\ 2/
**/PlaudSDK*/PlaudSDK/
ios/ReactNativeDemo/PlaudSDK/

# React Native generated files
metro.config.js.bak
.expo/

# iOS temporary files
